rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is admin - Only Yondaime has access
    function isAdmin() {
      return request.auth != null && 
        request.auth.token.email == 'edm21179@gmail.com';
    }

    // App "admin" role stored in userRoles (matches isUserAdmin in roleManagement.ts)
    function isAppAdminUser() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/userRoles/$(request.auth.uid)) &&
        (
          get(/databases/$(database)/documents/userRoles/$(request.auth.uid)).data.role == 'admin' ||
          (
            get(/databases/$(database)/documents/userRoles/$(request.auth.uid)).data.roles != null &&
            get(/databases/$(database)/documents/userRoles/$(request.auth.uid)).data.roles.hasAny(['admin'])
          )
        );
    }

    // Staff who can manage any live session (matches inSessionRooms admin checks)
    function isLiveEventStaff() {
      return request.auth != null && (
        request.auth.token.email in ['edm21179@gmail.com', 'eddymosley@compscihigh.org', 'admin@mstgames.net', 'eddymosley9@gmail.com'] ||
        request.auth.token.email.matches('.*@mstgames\\.net$') ||
        request.auth.token.email.matches('.*@compscihigh\\.org$')
      );
    }

    // Teachers / admins listing assessment goals, results, habits by assessmentId (queries must not depend only on resource.studentId).
    function isAssessmentDashboardStaff() {
      return isLiveEventStaff() || isAdmin() || isAppAdminUser();
    }

    // Session host (teacher) — not in classrooms.students; must read quizSession/stats for hosting.
    function isInSessionRoomHost(sessionId) {
      return request.auth != null &&
        exists(/databases/$(database)/documents/inSessionRooms/$(sessionId)) &&
        (
          get(/databases/$(database)/documents/inSessionRooms/$(sessionId)).data.hostUid == request.auth.uid ||
          get(/databases/$(database)/documents/inSessionRooms/$(sessionId)).data.teacherId == request.auth.uid
        );
    }

    // Student enrolled in the class for this session, session host, or staff
    function canReadInSessionRoomSession(sessionId) {
      return isLiveEventStaff() || isInSessionRoomHost(sessionId) || (
        request.auth != null &&
        exists(/databases/$(database)/documents/inSessionRooms/$(sessionId)) &&
        exists(/databases/$(database)/documents/classrooms/$(get(/databases/$(database)/documents/inSessionRooms/$(sessionId)).data.classId)) &&
        request.auth.uid in get(/databases/$(database)/documents/classrooms/$(get(/databases/$(database)/documents/inSessionRooms/$(sessionId)).data.classId)).data.students
      );
    }
    
    // Users collection - allow users to read/write their own documents
    // SECURITY NOTE: Challenge reset prevention is enforced at application level.
    // Firestore rules have limitations with nested field validation (chapters.challenges),
    // so reset prevention relies on UI/function-level admin checks.
    // Admins can always write (for testing/debugging).
    // NOTE: PP field updates should ideally be restricted to Cloud Functions only.
    // For now, we allow users to update their own PP (check-in rewards use transactions).
    match /users/{userId} {
      allow read: if request.auth != null && 
        (request.auth.uid == userId || isAdmin());
      // Allow write but note that PP updates should be done via transactions/Cloud Functions
      allow write: if request.auth != null && 
        (request.auth.uid == userId || isAdmin());
      
      // Protect rewardClaims subcollection - prevent deletion (idempotency protection)
      match /rewardClaims/{challengeId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create, update: if request.auth != null && request.auth.uid == userId;
        // Prevent deletion to maintain idempotency records
        allow delete: if isAdmin();
      }

      // Mission sequence reflections (when not merged into assessmentGoals) — self only
      match /missionReflectionResponses/{docId} {
        allow read, create: if request.auth != null && request.auth.uid == userId;
        allow update, delete: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // Users collection - allow scorekeepers to read all users
    match /users/{userId} {
      allow read: if request.auth != null && 
        exists(/databases/$(database)/documents/userRoles/$(request.auth.uid)) &&
        (get(/databases/$(database)/documents/userRoles/$(request.auth.uid)).data.role == 'scorekeeper' ||
         (get(/databases/$(database)/documents/userRoles/$(request.auth.uid)).data.roles != null && 
          get(/databases/$(database)/documents/userRoles/$(request.auth.uid)).data.roles.hasAny(['scorekeeper'])));
      
      // Protect rewardClaims subcollection for scorekeepers (read-only)
      match /rewardClaims/{challengeId} {
        allow read: if request.auth != null && 
          exists(/databases/$(database)/documents/userRoles/$(request.auth.uid)) &&
          (get(/databases/$(database)/documents/userRoles/$(request.auth.uid)).data.role == 'scorekeeper' ||
           (get(/databases/$(database)/documents/userRoles/$(request.auth.uid)).data.roles != null && 
            get(/databases/$(database)/documents/userRoles/$(request.auth.uid)).data.roles.hasAny(['scorekeeper'])));
      }
    }
    
    // Students collection.
    // Read is open to authenticated users so Vault Siege can list valid targets.
    // Write remains restricted to self/admin.
    match /students/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && 
        (request.auth.uid == userId || isAdmin());
    }
    
    // Students collection - allow scorekeepers to read all students
    match /students/{userId} {
      allow read: if request.auth != null && 
        exists(/databases/$(database)/documents/userRoles/$(request.auth.uid)) &&
        (get(/databases/$(database)/documents/userRoles/$(request.auth.uid)).data.role == 'scorekeeper' ||
         (get(/databases/$(database)/documents/userRoles/$(request.auth.uid)).data.roles != null && 
          get(/databases/$(database)/documents/userRoles/$(request.auth.uid)).data.roles.hasAny(['scorekeeper'])));
    }

    // Per-student settings (e.g. Live Feed privacy — liveFeedPrivacy.ts)
    match /students/{userId}/settings/{settingsDocId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Per-student daily challenge progress (not covered by students/{userId} alone — subcollections need their own rule)
    match /students/{userId}/dailyChallenges/{progressDocId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Weekly player goals (Live Event metrics + custom admin-verified)
    match /students/{userId}/weeklyGoals/{goalId} {
      allow read: if request.auth != null && (
        request.auth.uid == userId || isAdmin()
      );
      allow create, update, delete: if request.auth != null && (
        request.auth.uid == userId || isAdmin()
      );
    }

    // Badge reward queue — RewardNotifier / BadgeRewardNotifier; BadgeManager creates docs for students.
    match /students/{userId}/badgeNotifications/{notificationId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && (
        isAdmin() ||
        isLiveEventStaff() ||
        request.auth.token.email in ['edm21179@gmail.com', 'eddymosley@compscihigh.org', 'admin@mstgames.net', 'eddymosley9@gmail.com'] ||
        request.auth.token.email.matches('.*@mstgames\\.net$') ||
        request.auth.token.email.matches('.*@compscihigh\\.org$')
      );
      allow update, delete: if request.auth != null && (
        request.auth.uid == userId ||
        isAdmin() ||
        isLiveEventStaff() ||
        request.auth.token.email in ['edm21179@gmail.com', 'eddymosley@compscihigh.org', 'admin@mstgames.net', 'eddymosley9@gmail.com'] ||
        request.auth.token.email.matches('.*@mstgames\\.net$') ||
        request.auth.token.email.matches('.*@compscihigh\\.org$')
      );
    }
    
    // Profiles collection - allow users to read/write their own profile
    match /profiles/{userId} {
      allow read, write: if request.auth != null && 
        (request.auth.uid == userId || isAdmin());
    }
    
    // Profiles collection - allow scorekeepers to read all profiles
    match /profiles/{userId} {
      allow read: if request.auth != null && 
        exists(/databases/$(database)/documents/userRoles/$(request.auth.uid)) &&
        (get(/databases/$(database)/documents/userRoles/$(request.auth.uid)).data.role == 'scorekeeper' ||
         (get(/databases/$(database)/documents/userRoles/$(request.auth.uid)).data.roles != null && 
          get(/databases/$(database)/documents/userRoles/$(request.auth.uid)).data.roles.hasAny(['scorekeeper'])));
    }
    
    // Test account access - allow admin access to test accounts
    // Support both legacy test-account-001 and new testAccounts collection
    match /users/{userId} {
      // Allow admin access to any test account (test-account-*)
      allow read, write: if request.auth != null && 
        userId.matches('test-account-.*') &&
        isAdmin();
    }
    
    match /students/{userId} {
      // Allow admin access to any test account (test-account-*)
      allow read, write: if request.auth != null && 
        userId.matches('test-account-.*') &&
        isAdmin();
    }
    
    match /profiles/{userId} {
      // Allow admin access to any test account (test-account-*)
      allow read, write: if request.auth != null && 
        userId.matches('test-account-.*') &&
        isAdmin();
    }
    
    // Test Accounts collection - only admins can read/write
    match /testAccounts/{testAccountId} {
      allow read, write: if isAdmin();
    }
    
    // Challenge submissions - allow users to read/write their own submissions
    match /challengeSubmissions/{submissionId} {
      allow read, write: if request.auth != null && 
        (resource.data.userId == request.auth.uid || 
         request.auth.token.email in ['edm21179@gmail.com', 'eddymosley@compscihigh.org', 'admin@mstgames.net'] ||
         request.auth.token.email.matches('.*@mstgames\\.net$') ||
         request.auth.token.email.matches('.*@compscihigh\\.org$'));
      
      // Allow creation of new submissions
      allow create: if request.auth != null && 
        (request.auth.uid != null ||
         request.auth.token.email in ['edm21179@gmail.com', 'eddymosley@compscihigh.org', 'admin@mstgames.net'] ||
         request.auth.token.email.matches('.*@mstgames\\.net$') ||
         request.auth.token.email.matches('.*@compscihigh\\.org$'));
    }
    
    // Chapter classroom mappings - allow admins to manage
    match /chapterClassroomMap/{mappingId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && 
        (request.auth.token.email in ['edm21179@gmail.com', 'eddymosley@compscihigh.org', 'admin@mstgames.net'] ||
         request.auth.token.email.matches('.*@mstgames\\.net$') ||
         request.auth.token.email.matches('.*@compscihigh\\.org$'));
    }
    
    // Notifications - allow users to read their own notifications
    match /notifications/{notificationId} {
      allow read, write: if request.auth != null && 
        (resource.data.userId == request.auth.uid || 
         request.auth.token.email in ['edm21179@gmail.com', 'eddymosley@compscihigh.org', 'admin@mstgames.net'] ||
         request.auth.token.email.matches('.*@mstgames\\.net$') ||
         request.auth.token.email.matches('.*@compscihigh\\.org$'));
      
      // Allow creation of new notifications
      allow create: if request.auth != null && 
        (request.auth.uid != null ||
         request.auth.token.email in ['edm21179@gmail.com', 'eddymosley@compscihigh.org', 'admin@mstgames.net'] ||
         request.auth.token.email.matches('.*@mstgames\\.net$') ||
         request.auth.token.email.matches('.*@compscihigh\\.org$'));
    }
    
    // Student notifications subcollection - allow users to read their own notifications, anyone to create
    match /students/{userId}/notifications/{notificationId} {
      allow read, write: if request.auth != null && 
        (request.auth.uid == userId || 
         request.auth.token.email in ['edm21179@gmail.com', 'eddymosley@compscihigh.org', 'admin@mstgames.net', 'eddymosley9@gmail.com'] ||
         request.auth.token.email.matches('.*@mstgames\\.net$') ||
         request.auth.token.email.matches('.*@compscihigh\\.org$'));
      
      // Allow any authenticated user to create notifications (for battle notifications, etc.)
      allow create: if request.auth != null;
    }
    
    // User roles collection - allow users to read their own role, admins to manage all roles
    match /userRoles/{userId} {
      allow read: if request.auth != null && 
        (request.auth.uid == userId || 
         request.auth.token.email in ['edm21179@gmail.com', 'eddymosley@compscihigh.org', 'admin@mstgames.net'] ||
         request.auth.token.email.matches('.*@mstgames\\.net$') ||
         request.auth.token.email.matches('.*@compscihigh\\.org$'));
      allow write: if request.auth != null && 
        (request.auth.token.email in ['edm21179@gmail.com', 'eddymosley@compscihigh.org', 'admin@mstgames.net'] ||
         request.auth.token.email.matches('.*@mstgames\\.net$') ||
         request.auth.token.email.matches('.*@compscihigh\\.org$'));
    }
    
    // Classrooms collection - allow admins to manage classrooms
    match /classrooms/{classroomId} {
      allow read: if request.auth != null && 
        (request.auth.token.email in ['edm21179@gmail.com', 'eddymosley@compscihigh.org', 'admin@mstgames.net', 'eddymosley9@gmail.com'] ||
         request.auth.token.email.matches('.*@mstgames\\.net$') ||
         request.auth.token.email.matches('.*@compscihigh\\.org$'));
      allow write: if request.auth != null && 
        (request.auth.token.email in ['edm21179@gmail.com', 'eddymosley@compscihigh.org', 'admin@mstgames.net'] ||
         request.auth.token.email.matches('.*@mstgames\\.net$') ||
         request.auth.token.email.matches('.*@compscihigh\\.org$'));
    }
    
    // Classrooms collection - allow scorekeepers to read classrooms
    match /classrooms/{classroomId} {
      allow read: if request.auth != null && 
        exists(/databases/$(database)/documents/userRoles/$(request.auth.uid)) &&
        (get(/databases/$(database)/documents/userRoles/$(request.auth.uid)).data.role == 'scorekeeper' ||
         (get(/databases/$(database)/documents/userRoles/$(request.auth.uid)).data.roles != null && 
          get(/databases/$(database)/documents/userRoles/$(request.auth.uid)).data.roles.hasAny(['scorekeeper'])));
    }

    // Classrooms - enrolled students may read their own classes (needed for assessment goals notifier,
    // array-contains queries, and for assessment/inSession rules that get() classroom docs).
    match /classrooms/{classroomId} {
      allow read: if request.auth != null &&
        'students' in resource.data &&
        request.auth.uid in resource.data.students;
    }
    
    // Badges collection - allow admins to manage badges
    match /badges/{badgeId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && 
        (request.auth.token.email in ['edm21179@gmail.com', 'eddymosley@compscihigh.org', 'admin@mstgames.net'] ||
         request.auth.token.email.matches('.*@mstgames\\.net$') ||
         request.auth.token.email.matches('.*@compscihigh\\.org$'));
    }
    
    // PP Change Requests collection - allow scorekeepers to create, admins to manage
    match /ppChangeRequests/{requestId} {
      allow create: if request.auth != null && 
        exists(/databases/$(database)/documents/userRoles/$(request.auth.uid)) &&
        (get(/databases/$(database)/documents/userRoles/$(request.auth.uid)).data.role == 'scorekeeper' ||
         (get(/databases/$(database)/documents/userRoles/$(request.auth.uid)).data.roles != null && 
          get(/databases/$(database)/documents/userRoles/$(request.auth.uid)).data.roles.hasAny(['scorekeeper'])));
      allow read, write: if request.auth != null && 
        (request.auth.token.email in ['edm21179@gmail.com', 'eddymosley@compscihigh.org', 'admin@mstgames.net', 'eddymosley9@gmail.com'] ||
         request.auth.token.email.matches('.*@mstgames\\.net$') ||
         request.auth.token.email.matches('.*@compscihigh\\.org$'));
    }
    
    // PP Change Sessions collection - allow scorekeepers to create, admins to manage
    match /ppChangeSessions/{sessionId} {
      allow create: if request.auth != null && 
        exists(/databases/$(database)/documents/userRoles/$(request.auth.uid)) &&
        (get(/databases/$(database)/documents/userRoles/$(request.auth.uid)).data.role == 'scorekeeper' ||
         (get(/databases/$(database)/documents/userRoles/$(request.auth.uid)).data.roles != null && 
          get(/databases/$(database)/documents/userRoles/$(request.auth.uid)).data.roles.hasAny(['scorekeeper'])));
      allow read, write: if request.auth != null && 
        (request.auth.token.email in ['edm21179@gmail.com', 'eddymosley@compscihigh.org', 'admin@mstgames.net', 'eddymosley9@gmail.com'] ||
         request.auth.token.email.matches('.*@mstgames\\.net$') ||
         request.auth.token.email.matches('.*@compscihigh\\.org$'));
    }
    
    // Assessment Goals Collections
    // Assessments collection - allow students to read assessments for their class, admins to manage
    match /assessments/{assessmentId} {
      // Students can read assessments if they're in the class
      allow read: if request.auth != null && (
        // Admin access
        request.auth.token.email in ['edm21179@gmail.com', 'eddymosley@compscihigh.org', 'admin@mstgames.net', 'eddymosley9@gmail.com'] ||
        request.auth.token.email.matches('.*@mstgames\\.net$') ||
        request.auth.token.email.matches('.*@compscihigh\\.org$') ||
        // Student access - check if student is in the class
        (exists(/databases/$(database)/documents/classrooms/$(resource.data.classId)) &&
         request.auth.uid in get(/databases/$(database)/documents/classrooms/$(resource.data.classId)).data.students)
      );
      // Admins manage assessments (create / full update / delete)
      allow write: if request.auth != null && 
        (request.auth.token.email in ['edm21179@gmail.com', 'eddymosley@compscihigh.org', 'admin@mstgames.net'] ||
         request.auth.token.email.matches('.*@mstgames\\.net$') ||
         request.auth.token.email.matches('.*@compscihigh\\.org$'));
      // Enrolled students may bump goal counters only (habit submissions + set goal call increment numGoalsSet).
      // Without this, mission reflections and goal setup fail after writing habitSubmissions / assessmentGoals.
      allow update: if request.auth != null &&
        exists(/databases/$(database)/documents/classrooms/$(resource.data.classId)) &&
        request.auth.uid in get(/databases/$(database)/documents/classrooms/$(resource.data.classId)).data.students &&
        request.resource.data.classId == resource.data.classId &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['numGoalsSet']);
    }
    
    // Assessment Goals collection - students can create/update their own goals if assessment is not locked
    match /assessmentGoals/{goalId} {
      allow get: if request.auth != null && (
        request.auth.token.email in ['edm21179@gmail.com', 'eddymosley@compscihigh.org', 'admin@mstgames.net', 'eddymosley9@gmail.com'] ||
        request.auth.token.email.matches('.*@mstgames\\.net$') ||
        request.auth.token.email.matches('.*@compscihigh\\.org$') ||
        request.auth.uid == resource.data.studentId
      );
      allow list: if isAssessmentDashboardStaff();
      allow list: if request.auth != null && resource.data.studentId == request.auth.uid;
      // Create: admins/staff OR enrolled student when assessment is not locked
      allow create: if request.auth != null && (
        request.auth.token.email in ['edm21179@gmail.com', 'eddymosley@compscihigh.org', 'admin@mstgames.net'] ||
        request.auth.token.email.matches('.*@mstgames\\.net$') ||
        request.auth.token.email.matches('.*@compscihigh\\.org$') ||
        (request.auth.uid == request.resource.data.studentId &&
         exists(/databases/$(database)/documents/assessments/$(request.resource.data.assessmentId)) &&
         get(/databases/$(database)/documents/assessments/$(request.resource.data.assessmentId)).data.isLocked == false &&
         exists(/databases/$(database)/documents/classrooms/$(request.resource.data.classId)) &&
         request.auth.uid in get(/databases/$(database)/documents/classrooms/$(request.resource.data.classId)).data.students)
      );
      // Update: admins OR student (unlocked goals) OR student evidence-only when locked (Live Event → Assessment Goals)
      allow update: if request.auth != null && (
        request.auth.token.email in ['edm21179@gmail.com', 'eddymosley@compscihigh.org', 'admin@mstgames.net'] ||
        request.auth.token.email.matches('.*@mstgames\\.net$') ||
        request.auth.token.email.matches('.*@compscihigh\\.org$') ||
        (request.auth.uid == request.resource.data.studentId &&
         exists(/databases/$(database)/documents/assessments/$(request.resource.data.assessmentId)) &&
         get(/databases/$(database)/documents/assessments/$(request.resource.data.assessmentId)).data.isLocked == false &&
         exists(/databases/$(database)/documents/classrooms/$(request.resource.data.classId)) &&
         request.auth.uid in get(/databases/$(database)/documents/classrooms/$(request.resource.data.classId)).data.students) ||
        (request.auth.uid == resource.data.studentId &&
         request.resource.data.studentId == resource.data.studentId &&
         request.resource.data.assessmentId == resource.data.assessmentId &&
         request.resource.data.classId == resource.data.classId &&
         request.resource.data.id == resource.data.id &&
         exists(/databases/$(database)/documents/assessments/$(resource.data.assessmentId)) &&
         get(/databases/$(database)/documents/assessments/$(resource.data.assessmentId)).data.isLocked == true &&
         exists(/databases/$(database)/documents/classrooms/$(resource.data.classId)) &&
         request.auth.uid in get(/databases/$(database)/documents/classrooms/$(resource.data.classId)).data.students &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['evidence', 'updatedAt']))
      );
      // Only admins can delete
      allow delete: if request.auth != null && 
        (request.auth.token.email in ['edm21179@gmail.com', 'eddymosley@compscihigh.org', 'admin@mstgames.net'] ||
         request.auth.token.email.matches('.*@mstgames\\.net$') ||
         request.auth.token.email.matches('.*@compscihigh\\.org$'));
    }
    
    // Assessment Results collection - students can read their own results, admins can manage all
    match /assessmentResults/{resultId} {
      allow get: if request.auth != null && (
        request.auth.token.email in ['edm21179@gmail.com', 'eddymosley@compscihigh.org', 'admin@mstgames.net', 'eddymosley9@gmail.com'] ||
        request.auth.token.email.matches('.*@mstgames\\.net$') ||
        request.auth.token.email.matches('.*@compscihigh\\.org$') ||
        request.auth.uid == resource.data.studentId
      );
      allow list: if isAssessmentDashboardStaff();
      allow list: if request.auth != null && resource.data.studentId == request.auth.uid;
      // Only admins can create/update results
      allow write: if request.auth != null && 
        (request.auth.token.email in ['edm21179@gmail.com', 'eddymosley@compscihigh.org', 'admin@mstgames.net'] ||
         request.auth.token.email.matches('.*@mstgames\\.net$') ||
         request.auth.token.email.matches('.*@compscihigh\\.org$'));
    }

    // Habit submissions (habits-type assessments) — was missing; fell through to deny-all.
    match /habitSubmissions/{submissionId} {
      allow get: if request.auth != null && (
        isLiveEventStaff() ||
        isAdmin() || isAppAdminUser() ||
        resource.data.studentId == request.auth.uid ||
        (exists(/databases/$(database)/documents/classrooms/$(resource.data.classId)) &&
         request.auth.uid in get(/databases/$(database)/documents/classrooms/$(resource.data.classId)).data.students)
      );
      // Teachers run queries by assessmentId only — list must allow staff/admin without resource-only constraints.
      allow list: if isAssessmentDashboardStaff();
      allow list: if request.auth != null && resource.data.studentId == request.auth.uid;
      allow create, update: if request.auth != null && (
        isLiveEventStaff() ||
        (request.resource.data.studentId == request.auth.uid &&
         exists(/databases/$(database)/documents/classrooms/$(request.resource.data.classId)) &&
         request.auth.uid in get(/databases/$(database)/documents/classrooms/$(request.resource.data.classId)).data.students)
      );
      allow delete: if isLiveEventStaff();

      // Class Flow sprint stats for habit goals (written by session host; read by student + staff).
      match /liveEventSessions/{sessionId} {
        allow get: if request.auth != null && (
          isAssessmentDashboardStaff() ||
          get(/databases/$(database)/documents/habitSubmissions/$(submissionId)).data.studentId == request.auth.uid
        );
        allow list: if request.auth != null && (
          isAssessmentDashboardStaff() ||
          get(/databases/$(database)/documents/habitSubmissions/$(submissionId)).data.studentId == request.auth.uid
        );
        allow create, update: if request.auth != null && (
          isLiveEventStaff() ||
          isInSessionRoomHost(sessionId)
        );
        allow delete: if false;
      }
    }
    
    // PP Ledger collection - students can read their own entries, admins can read all
    match /ppLedger/{entryId} {
      // Students can read their own ledger entries
      allow read: if request.auth != null && (
        // Admin access
        request.auth.token.email in ['edm21179@gmail.com', 'eddymosley@compscihigh.org', 'admin@mstgames.net', 'eddymosley9@gmail.com'] ||
        request.auth.token.email.matches('.*@mstgames\\.net$') ||
        request.auth.token.email.matches('.*@compscihigh\\.org$') ||
        // Student can read their own entries
        request.auth.uid == resource.data.studentId
      );
      // Only system (via Cloud Functions or admin) can create ledger entries
      // For now, allow admins to create (will be restricted to Cloud Functions later)
      allow create: if request.auth != null && 
        (request.auth.token.email in ['edm21179@gmail.com', 'eddymosley@compscihigh.org', 'admin@mstgames.net'] ||
         request.auth.token.email.matches('.*@mstgames\\.net$') ||
         request.auth.token.email.matches('.*@compscihigh\\.org$'));
      // No updates or deletes allowed (ledger is append-only)
      allow update, delete: if false;
    }
    
    // Vaults collection.
    // Vault Siege reads and writes target vault docs directly from authenticated clients.
    match /vaults/{userId} {
      allow read, write: if request.auth != null;
    }
    
    // Battle Moves collection - allow users to read/write their own moves
    match /battleMoves/{userId} {
      allow read, write: if request.auth != null && 
        (request.auth.uid == userId || 
         request.auth.token.email in ['edm21179@gmail.com', 'eddymosley@compscihigh.org', 'admin@mstgames.net', 'eddymosley9@gmail.com'] ||
         request.auth.token.email.matches('.*@mstgames\\.net$') ||
         request.auth.token.email.matches('.*@compscihigh\\.org$'));
    }
    
    // Legacy moves/{userId} doc (same shape as battleMoves; used by older clients + power level recalc)
    match /moves/{userId} {
      allow read, write: if request.auth != null && 
        (request.auth.uid == userId || 
         request.auth.token.email in ['edm21179@gmail.com', 'eddymosley@compscihigh.org', 'admin@mstgames.net', 'eddymosley9@gmail.com'] ||
         request.auth.token.email.matches('.*@mstgames\\.net$') ||
         request.auth.token.email.matches('.*@compscihigh\\.org$'));
    }
    
    // Battle Action Cards collection - allow users to read/write their own cards
    match /battleActionCards/{userId} {
      allow read, write: if request.auth != null && 
        (request.auth.uid == userId || 
         request.auth.token.email in ['edm21179@gmail.com', 'eddymosley@compscihigh.org', 'admin@mstgames.net', 'eddymosley9@gmail.com'] ||
         request.auth.token.email.matches('.*@mstgames\\.net$') ||
         request.auth.token.email.matches('.*@compscihigh\\.org$'));
    }

    // Legacy Season 0 battle pass (claim tracking + premium flag). Doc ids: "{uid}_season0", "{uid}_season1", etc.
    match /battlePass/{docId} {
      allow read, write: if request.auth != null && (
        (docId.size() >= request.auth.uid.size() + 7 &&
          docId.substring(0, request.auth.uid.size() + 7) == request.auth.uid + '_season') ||
        isAdmin()
      );
    }
    
    // Battle Lobbies collection - allow authenticated users to read/write
    match /battleLobbies/{lobbyId} {
      allow read, write: if request.auth != null;
    }
    
    // Manifest Milestones collection - allow authenticated users to read
    match /manifestMilestones/{manifestType} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && 
        (request.auth.token.email in ['edm21179@gmail.com', 'eddymosley@compscihigh.org', 'admin@mstgames.net', 'eddymosley9@gmail.com'] ||
         request.auth.token.email.matches('.*@mstgames\\.net$') ||
         request.auth.token.email.matches('.*@compscihigh\\.org$'));
    }
    
    // Elemental Milestones collection - allow authenticated users to read
    match /elementalMilestones/{elementalType} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && 
        (request.auth.token.email in ['edm21179@gmail.com', 'eddymosley@compscihigh.org', 'admin@mstgames.net', 'eddymosley9@gmail.com'] ||
         request.auth.token.email.matches('.*@mstgames\\.net$') ||
         request.auth.token.email.matches('.*@compscihigh\\.org$'));
    }
    
    // Admin Notifications collection - allow authenticated users to create, admins to read/write
    match /adminNotifications/{notificationId} {
      allow create: if request.auth != null;
      allow read, write: if request.auth != null && 
        (request.auth.token.email in ['edm21179@gmail.com', 'eddymosley@compscihigh.org', 'admin@mstgames.net', 'eddymosley9@gmail.com'] ||
         request.auth.token.email.matches('.*@mstgames\\.net$') ||
         request.auth.token.email.matches('.*@compscihigh\\.org$'));
    }
    
    // Offline Moves collection - allow authenticated users to create, users to read/write their own moves
    match /offlineMoves/{moveId} {
      allow create: if request.auth != null;
      allow read, write: if request.auth != null && 
        (request.auth.uid == resource.data.userId || 
         request.auth.token.email in ['edm21179@gmail.com', 'eddymosley@compscihigh.org', 'admin@mstgames.net', 'eddymosley9@gmail.com'] ||
         request.auth.token.email.matches('.*@mstgames\\.net$') ||
         request.auth.token.email.matches('.*@compscihigh\\.org$'));
    }
    
    // Vault Siege Attacks collection - allow authenticated users to create, users to read their own attacks
    match /vaultSiegeAttacks/{attackId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && 
        (request.auth.uid == resource.data.attackerId || 
         request.auth.uid == resource.data.targetId ||
         request.auth.token.email in ['edm21179@gmail.com', 'eddymosley@compscihigh.org', 'admin@mstgames.net', 'eddymosley9@gmail.com'] ||
         request.auth.token.email.matches('.*@mstgames\\.net$') ||
         request.auth.token.email.matches('.*@compscihigh\\.org$'));
      allow write: if request.auth != null && 
        (request.auth.token.email in ['edm21179@gmail.com', 'eddymosley@compscihigh.org', 'admin@mstgames.net', 'eddymosley9@gmail.com'] ||
         request.auth.token.email.matches('.*@mstgames\\.net$') ||
         request.auth.token.email.matches('.*@compscihigh\\.org$'));
    }
    
    // Used Items collection - allow authenticated users to create, users to read their own items, admins to manage all
    match /usedItems/{itemId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && 
        (request.auth.uid == resource.data.userId || 
         request.auth.token.email in ['edm21179@gmail.com', 'eddymosley@compscihigh.org', 'admin@mstgames.net', 'eddymosley9@gmail.com'] ||
         request.auth.token.email.matches('.*@mstgames\\.net$') ||
         request.auth.token.email.matches('.*@compscihigh\\.org$'));
      allow write: if request.auth != null && 
        (request.auth.token.email in ['edm21179@gmail.com', 'eddymosley@compscihigh.org', 'admin@mstgames.net', 'eddymosley9@gmail.com'] ||
         request.auth.token.email.matches('.*@mstgames\\.net$') ||
         request.auth.token.email.matches('.*@compscihigh\\.org$'));
    }
    
    // Practice Battles collection - allow authenticated users to create, users to read their own battles, admins to manage all
    match /practiceBattles/{battleId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && 
        (request.auth.uid == resource.data.userId || 
         request.auth.token.email in ['edm21179@gmail.com', 'eddymosley@compscihigh.org', 'admin@mstgames.net', 'eddymosley9@gmail.com'] ||
         request.auth.token.email.matches('.*@mstgames\\.net$') ||
         request.auth.token.email.matches('.*@compscihigh\\.org$'));
      allow write: if request.auth != null && 
        (request.auth.token.email in ['edm21179@gmail.com', 'eddymosley@compscihigh.org', 'admin@mstgames.net', 'eddymosley9@gmail.com'] ||
         request.auth.token.email.matches('.*@mstgames\\.net$') ||
         request.auth.token.email.matches('.*@compscihigh\\.org$'));
    }
    
    // Active PP Boosts collection - allow users to read/write their own boosts
    match /activePPBoosts/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Battle Rooms collection - allow all authenticated users to read waiting rooms to join them
    match /battleRooms/{roomId} {
      // Allow reading if user is host, participant, or room is waiting/in-progress (so they can join or rejoin)
      // Simplified rule to work better with collection queries
      allow read: if request.auth != null && (
        resource.data.hostId == request.auth.uid || 
        request.auth.uid in resource.data.participants ||
        resource.data.status == 'waiting' ||
        (resource.data.status == 'in-progress' && request.auth.uid in resource.data.participants)
      );
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        resource.data.hostId == request.auth.uid || 
        request.auth.uid in resource.data.participants
      );
      
      // Moves subcollection - allow participants to read/write moves
      match /moves/{moveId} {
        allow read, write: if request.auth != null && 
          request.auth.uid in get(/databases/$(database)/documents/battleRooms/$(roomId)).data.participants;
      }
    }
    
    // Story progress collection - allow users to read/write their own progress
    match /storyProgress/{userId} {
      allow read, write: if request.auth != null && 
        (request.auth.uid == userId || 
         request.auth.token.email in ['edm21179@gmail.com', 'eddymosley@compscihigh.org', 'admin@mstgames.net', 'eddymosley9@gmail.com'] ||
         request.auth.token.email.matches('.*@mstgames\\.net$') ||
         request.auth.token.email.matches('.*@compscihigh\\.org$'));
    }
    
    // In Session Rooms collection - classroom battle sessions
    match /inSessionRooms/{sessionId} {
      // Allow read if user is in the class, session host/teacher, or staff (hosts are often not in classrooms.students)
      allow read: if request.auth != null && (
        // Admin/Yondaime can read all sessions
        request.auth.token.email in ['edm21179@gmail.com', 'eddymosley@compscihigh.org', 'admin@mstgames.net', 'eddymosley9@gmail.com'] ||
        request.auth.token.email.matches('.*@mstgames\\.net$') ||
        request.auth.token.email.matches('.*@compscihigh\\.org$') ||
        isInSessionRoomHost(sessionId) ||
        // Student can read if they're in the class
        (exists(/databases/$(database)/documents/classrooms/$(resource.data.classId)) &&
         request.auth.uid in get(/databases/$(database)/documents/classrooms/$(resource.data.classId)).data.students)
      );
      
      // Allow create/update/delete only for admins/Yondaime or host
      allow create: if request.auth != null && (
        request.auth.token.email in ['edm21179@gmail.com', 'eddymosley@compscihigh.org', 'admin@mstgames.net', 'eddymosley9@gmail.com'] ||
        request.auth.token.email.matches('.*@mstgames\\.net$') ||
        request.auth.token.email.matches('.*@compscihigh\\.org$')
      );
      
      // Host/admin OR students in the session class (live event battle state, moves, revive potion, etc.)
      // teacherId matches hostUid on new sessions; allow both so older docs or edge cases still authorize the teacher.
      allow update: if request.auth != null && (
        resource.data.hostUid == request.auth.uid ||
        resource.data.teacherId == request.auth.uid ||
        request.auth.token.email in ['edm21179@gmail.com', 'eddymosley@compscihigh.org', 'admin@mstgames.net', 'eddymosley9@gmail.com'] ||
        request.auth.token.email.matches('.*@mstgames\\.net$') ||
        request.auth.token.email.matches('.*@compscihigh\\.org$') ||
        (exists(/databases/$(database)/documents/classrooms/$(resource.data.classId)) &&
         request.auth.uid in get(/databases/$(database)/documents/classrooms/$(resource.data.classId)).data.students)
      );
      
      allow delete: if request.auth != null && (
        request.auth.token.email in ['edm21179@gmail.com', 'eddymosley@compscihigh.org', 'admin@mstgames.net', 'eddymosley9@gmail.com'] ||
        request.auth.token.email.matches('.*@mstgames\\.net$') ||
        request.auth.token.email.matches('.*@compscihigh\\.org$')
      );
      
      // Players subcollection - students can write their own presence doc
      match /players/{playerId} {
        allow read: if request.auth != null; // Anyone in session can read player presence
        allow write: if request.auth != null && request.auth.uid == playerId; // Only own presence doc
      }
      
      // Actions subcollection - students can create actions, host can resolve
      match /actions/{actionId} {
        allow read: if request.auth != null; // Anyone in session can read actions
        allow create: if request.auth != null && (
          // Students in class can create actions
          (exists(/databases/$(database)/documents/classrooms/$(get(/databases/$(database)/documents/inSessionRooms/$(sessionId)).data.classId)) &&
           request.auth.uid in get(/databases/$(database)/documents/classrooms/$(get(/databases/$(database)/documents/inSessionRooms/$(sessionId)).data.classId)).data.students) ||
          // Admin/Yondaime can create actions
          request.auth.token.email in ['edm21179@gmail.com', 'eddymosley@compscihigh.org', 'admin@mstgames.net', 'eddymosley9@gmail.com'] ||
          request.auth.token.email.matches('.*@mstgames\\.net$') ||
          request.auth.token.email.matches('.*@compscihigh\\.org$')
        );
        allow update: if request.auth != null && (
          // Host can resolve actions
          get(/databases/$(database)/documents/inSessionRooms/$(sessionId)).data.hostUid == request.auth.uid ||
          // Admin/Yondaime can resolve actions
          request.auth.token.email in ['edm21179@gmail.com', 'eddymosley@compscihigh.org', 'admin@mstgames.net', 'eddymosley9@gmail.com'] ||
          request.auth.token.email.matches('.*@mstgames\\.net$') ||
          request.auth.token.email.matches('.*@compscihigh\\.org$')
        );
      }

      // Live quiz / battle royale state: quizSession/current (+ responses)
      match /quizSession/{quizDocId} {
        allow read: if canReadInSessionRoomSession(sessionId);
        allow create, update, delete: if request.auth != null && (
          isLiveEventStaff() ||
          get(/databases/$(database)/documents/inSessionRooms/$(sessionId)).data.hostUid == request.auth.uid
        );
        match /responses/{responseUid} {
          allow read: if canReadInSessionRoomSession(sessionId);
          allow create, update: if request.auth != null && (
            isLiveEventStaff() ||
            get(/databases/$(database)/documents/inSessionRooms/$(sessionId)).data.hostUid == request.auth.uid ||
            (request.auth.uid == responseUid && canReadInSessionRoomSession(sessionId))
          );
          allow delete: if request.auth != null && (
            isLiveEventStaff() ||
            get(/databases/$(database)/documents/inSessionRooms/$(sessionId)).data.hostUid == request.auth.uid
          );
        }
      }

      // Per-player session stats (skills used, PP, eliminations, etc.)
      match /stats/{playerId} {
        allow read: if canReadInSessionRoomSession(sessionId);
        allow create, update: if request.auth != null && (
          isLiveEventStaff() ||
          isInSessionRoomHost(sessionId) ||
          (request.auth.uid == playerId && canReadInSessionRoomSession(sessionId))
        );
        allow delete: if isLiveEventStaff();
      }
    }
    
    // Challenge completions collection - allow users to read/write their own completions
    match /challengeCompletions/{completionId} {
      allow read, write: if request.auth != null && 
        (resource.data.userId == request.auth.uid || 
         request.auth.token.email in ['edm21179@gmail.com', 'eddymosley@compscihigh.org', 'admin@mstgames.net', 'eddymosley9@gmail.com'] ||
         request.auth.token.email.matches('.*@mstgames\\.net$') ||
         request.auth.token.email.matches('.*@compscihigh\\.org$'));
      
      // Allow creation of new completions
      allow create: if request.auth != null && 
        (request.auth.uid != null ||
         request.auth.token.email in ['edm21179@gmail.com', 'eddymosley@compscihigh.org', 'admin@mstgames.net', 'eddymosley9@gmail.com'] ||
         request.auth.token.email.matches('.*@mstgames\\.net$') ||
         request.auth.token.email.matches('.*@compscihigh\\.org$'));
    }
    
    // Recent completions collection - allow users to read/write their own completions
    match /recentCompletions/{completionId} {
      allow read, write: if request.auth != null && 
        (resource.data.userId == request.auth.uid || 
         request.auth.token.email in ['edm21179@gmail.com', 'eddymosley@compscihigh.org', 'admin@mstgames.net', 'eddymosley9@gmail.com'] ||
         request.auth.token.email.matches('.*@mstgames\\.net$') ||
         request.auth.token.email.matches('.*@compscihigh\\.org$'));
      
      // Allow creation of new completions
      allow create: if request.auth != null && 
        (request.auth.uid != null ||
         request.auth.token.email in ['edm21179@gmail.com', 'eddymosley@compscihigh.org', 'admin@mstgames.net', 'eddymosley9@gmail.com'] ||
         request.auth.token.email.matches('.*@mstgames\\.net$') ||
         request.auth.token.email.matches('.*@compscihigh\\.org$'));
    }
    
    // Chapter classroom assignments collection - allow authenticated users to read/write
    match /chapterClassroomAssignments/{assignmentId} {
      allow read, write: if request.auth != null;
    }

    // Island Raid / chapter battle invites — BattleInvitationManager, BattleInviteModal (was missing → deny-all).
    match /battleInvitations/{invitationId} {
      allow read: if request.auth != null && (
        resource.data.toUserId == request.auth.uid ||
        resource.data.fromUserId == request.auth.uid ||
        isLiveEventStaff() ||
        isAdmin()
      );
      allow create: if request.auth != null &&
        request.resource.data.fromUserId == request.auth.uid &&
        request.resource.data.keys().hasAll(['gameId', 'fromUserId', 'toUserId', 'status']);
      allow update, delete: if request.auth != null && (
        resource.data.toUserId == request.auth.uid ||
        resource.data.fromUserId == request.auth.uid ||
        isLiveEventStaff() ||
        isAdmin()
      );
    }
    
    // Squad invitations collection - allow authenticated users to read/write
    match /squadInvitations/{invitationId} {
      allow read, write: if request.auth != null;
    }

    // Per-session quiz leaderboard ranks (uid -> rank) for school Leaderboard; no full session payload.
    match /liveEventPlacementRollups/{sessionId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && (
        isLiveEventStaff() ||
        (
          exists(/databases/$(database)/documents/inSessionRooms/$(sessionId)) &&
          (
            get(/databases/$(database)/documents/inSessionRooms/$(sessionId)).data.hostUid == request.auth.uid ||
            get(/databases/$(database)/documents/inSessionRooms/$(sessionId)).data.teacherId == request.auth.uid
          )
        )
      );
      allow delete: if isLiveEventStaff() || isAdmin();
    }
    
    // Squads collection - allow authenticated users to read/write
    match /squads/{squadId} {
      allow read, write: if request.auth != null;
      
      // Squad members are stored as objects [{ uid, displayName, ... }].
      // `request.auth.uid in members` is always false for object elements, so we use denormalized memberUids.
      function isSquadMember() {
        let squadData = get(/databases/$(database)/documents/squads/$(squadId)).data;
        return request.auth != null &&
          exists(/databases/$(database)/documents/squads/$(squadId)) &&
          squadData.memberUids is list &&
          request.auth.uid in squadData.memberUids;
      }
      
      // Stream messages subcollection - only squad members can read/write
      match /streamMessages/{messageId} {
        allow read: if request.auth != null && isSquadMember();
        allow create: if request.auth != null && 
          isSquadMember() &&
          // For chat messages, senderId must match auth user
          (request.resource.data.type == 'system' || 
           (request.resource.data.type == 'chat' && request.resource.data.senderId == request.auth.uid));
        // Users can only delete their own chat messages
        allow update, delete: if request.auth != null && 
          (isSquadMember() && resource.data.senderId == request.auth.uid) ||
          isAdmin();
      }
      
      // Daily check-ins subcollection - only squad members can read
      match /dailyCheckins/{dateKey} {
        allow read: if request.auth != null && isSquadMember();
        // Only allow creation/update through transactions (client-side for now)
        // In production, this should be restricted to Cloud Functions only
        allow create, update: if request.auth != null && isSquadMember();
        // Prevent deletion
        allow delete: if false;
      }
      allow read, write: if request.auth != null;
    }
    
    // Mindforge battles collection - allow users to create and read their own battles
    match /mindforgeBattles/{battleId} {
      allow create: if request.auth != null && 
        request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && 
        (resource.data.userId == request.auth.uid ||
         request.auth.token.email in ['edm21179@gmail.com', 'eddymosley@compscihigh.org', 'admin@mstgames.net', 'eddymosley9@gmail.com'] ||
         request.auth.token.email.matches('.*@mstgames\\.net$') ||
         request.auth.token.email.matches('.*@compscihigh\\.org$'));
      allow update, delete: if request.auth != null && 
        (resource.data.userId == request.auth.uid ||
         request.auth.token.email in ['edm21179@gmail.com', 'eddymosley@compscihigh.org', 'admin@mstgames.net', 'eddymosley9@gmail.com'] ||
         request.auth.token.email.matches('.*@mstgames\\.net$') ||
         request.auth.token.email.matches('.*@compscihigh\\.org$'));
    }
    
    // Mindforge questions collection - allow admins to manage, all users to read
    match /mindforgeQuestions/{questionId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null && 
        (request.auth.token.email in ['edm21179@gmail.com', 'eddymosley@compscihigh.org', 'admin@mstgames.net', 'eddymosley9@gmail.com'] ||
         request.auth.token.email.matches('.*@mstgames\\.net$') ||
         request.auth.token.email.matches('.*@compscihigh\\.org$'));
    }
    
    // Admin Settings — admins read/write all.
    // equippableArtifacts + marketplaceArtifacts: any signed-in user may READ (catalog metadata only;
    // equippable is needed for battle/skills UI; marketplace catalog for store parity / compensation UI).
    // Scorekeepers and other staff use Compensate without matching isAdmin() token email.
    match /adminSettings/{settingId} {
      allow read: if request.auth != null && (
        isAdmin() ||
        settingId == 'equippableArtifacts' ||
        settingId == 'marketplaceArtifacts' ||
        // CPU definitions for mission / island raid battles (MissionRunner, IslandRaidBattle)
        settingId == 'cpuOpponentMoves' ||
        // Flow / battle pass pointers (activeBattlePassSeasonId, energyTickCap) — clients need read for Home BP UI
        settingId == 'season1'
      );
      allow write: if request.auth != null && (isAdmin() || isAppAdminUser());
    }

    // RR Candy skill trees + other global config (e.g. rr_candy_trees_v1)
    match /system_config/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (isAdmin() || isAppAdminUser());
    }

    // Daily challenge definitions — full path (nested match under adminSettings alone can fail list/get in some clients)
    // Path: adminSettings/dailyChallenges/challenges/{challengeId}
    match /adminSettings/{settingId}/challenges/{challengeId} {
      // Students read the pool; admins always (covers Admin Panel if rule evaluation is strict)
      allow read: if request.auth != null && (
        settingId == 'dailyChallenges' ||
        isAdmin() ||
        isAppAdminUser()
      );
      allow write: if request.auth != null && (isAdmin() || isAppAdminUser());
    }
    
    // Season 1 battle pass definitions — all signed-in users may read (Home / BP UI); admins manage.
    match /seasons/{seasonId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (isAdmin() || isAppAdminUser());
    }

    // Island Raid Levels - read for all authenticated (lobby list, battle load), write for admins only
    match /islandRaidLevels/{levelId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }
    
    // Live Feed Posts collection - global feed for all authenticated users
    match /liveFeedPosts/{postId} {
      // Allow read for all authenticated users
      allow read: if request.auth != null;
      
      // Allow create: user creates their own post, OR admin creates a milestone (e.g. badge awarded to student)
      allow create: if request.auth != null &&
        request.resource.data.text is string &&
        request.resource.data.text.size() <= 240 &&
        request.resource.data.type in ['post', 'milestone'] &&
        request.resource.data.visibility == 'global' &&
        (request.resource.data.createdBy.uid == request.auth.uid ||
          (request.resource.data.type == 'milestone' && isAdmin()));
      
      // Allow delete/update only for own posts (not milestones)
      allow update, delete: if request.auth != null &&
        resource.data.type == 'post' &&
        resource.data.createdBy.uid == request.auth.uid;
      
      // Reactions subcollection
      match /reactions/{reactionUserId} {
        // Allow read for all authenticated users
        allow read: if request.auth != null;
        
        // Allow create/update if user is creating their own reaction
        allow create, update: if request.auth != null &&
          reactionUserId == request.auth.uid &&
          request.resource.data.uid == request.auth.uid;
        
        // Allow delete only own reactions
        allow delete: if request.auth != null &&
          reactionUserId == request.auth.uid;
      }
    }

    // Home / global banner strip — Banner.tsx listens on bannerMessages (was missing → deny-all).
    match /bannerMessages/{messageId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null && (
        isAdmin() ||
        isAppAdminUser() ||
        request.auth.token.email in ['edm21179@gmail.com', 'eddymosley@compscihigh.org', 'admin@mstgames.net', 'eddymosley9@gmail.com'] ||
        request.auth.token.email.matches('.*@mstgames\\.net$') ||
        request.auth.token.email.matches('.*@compscihigh\\.org$')
      );
    }
    
    // Player skill tree & battle loadout (NOT in-session battle players under inSessionRooms)
    // Path: players/{userId}/skill_state/main — equippedSkillIds, unlocked nodes, etc.
    match /players/{userId}/skill_state/{stateDocId} {
      allow read, write: if request.auth != null &&
        (request.auth.uid == userId || isAdmin());
    }

    // Training Grounds attempts — users create/read own; staff read all (admin analytics).
    match /trainingAttempts/{attemptId} {
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        isLiveEventStaff()
      );
      allow create: if request.auth != null &&
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if isLiveEventStaff();
    }

    // Training Grounds — published quiz sets + questions (live event quiz launch, Training Grounds page).
    // Was missing: fell through to deny-all and caused permission errors on getQuizSet / getQuestions.
    match /trainingQuizSets/{quizSetId} {
      allow read: if request.auth != null && (
        resource.data.isPublished == true ||
        isLiveEventStaff()
      );
      allow create, update, delete: if isLiveEventStaff();
      match /questions/{questionId} {
        allow read: if request.auth != null && (
          get(/databases/$(database)/documents/trainingQuizSets/$(quizSetId)).data.isPublished == true ||
          isLiveEventStaff()
        );
        allow create, update, delete: if isLiveEventStaff();
      }
    }

    // --- Player Journey & missions (were missing; default deny blocked templates + progress) ---
    match /missions/{missionId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null && (isAdmin() || isAppAdminUser());
    }

    match /playerMissions/{playerMissionId} {
      // Single-doc reads (MissionRunner, status checks).
      allow get: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        isAdmin() || isAppAdminUser()
      );
      // Queries: students use where('userId','==', auth.uid). Admins query by missionId only for bulk reset —
      // that list must be allowed without tying list permission to resource (see Firestore "secure queries").
      allow list: if request.auth != null && (isAdmin() || isAppAdminUser());
      allow list: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        isAdmin() || isAppAdminUser()
      );
    }

    match /playerStoryProgress/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Island Raid co-op / chapter battles (Timu Island, Squad Up, Island Raid lobby flow)
    match /islandRaidGames/{gameId} {
      // Allow get when the doc is missing (MissionRunner / solo rooms use the same gameId only under islandRaidBattleRooms).
      // Without this, exists() is false but rules still evaluate and deny reads on non-existent docs.
      allow read: if request.auth != null && (
        !exists(/databases/$(database)/documents/islandRaidGames/$(gameId)) ||
        (
          request.auth.uid == resource.data.hostId ||
          (resource.data.players is list && request.auth.uid in resource.data.players)
        )
      );
      allow create: if request.auth != null && (
        request.auth.uid == request.resource.data.hostId ||
        (request.resource.data.players is list && request.auth.uid in request.resource.data.players)
      );
      allow update, delete: if request.auth != null && (
        request.auth.uid == resource.data.hostId ||
        (resource.data.players is list && request.auth.uid in resource.data.players)
      );
    }

    match /islandRaidBattleRooms/{gameId} {
      function canAccessIslandRaidBattleRoomData() {
        return request.auth != null && (
          (resource.data.players is list && request.auth.uid in resource.data.players) ||
          (
            exists(/databases/$(database)/documents/islandRaidGames/$(gameId)) &&
            get(/databases/$(database)/documents/islandRaidGames/$(gameId)).data.players is list &&
            request.auth.uid in get(/databases/$(database)/documents/islandRaidGames/$(gameId)).data.players
          )
        );
      }
      /** Mid-battle join / reinforcement rooms (Missions + Island Raids): allow roster read before join. */
      function islandRaidBattleRoomJoinableRead() {
        return request.auth != null &&
          resource.data.joinableMidBattle == true &&
          (resource.data.status == 'active' || resource.data.status == 'wave_complete');
      }
      allow read: if canAccessIslandRaidBattleRoomData() || islandRaidBattleRoomJoinableRead();
      allow create: if request.auth != null &&
        request.resource.data.players is list &&
        request.auth.uid in request.resource.data.players;
      allow update, delete: if request.auth != null && (
        canAccessIslandRaidBattleRoomData() ||
        (request.resource.data.players is list && request.auth.uid in request.resource.data.players)
      );
    }

    // Island Run lobby list + co-op join (IslandRun.tsx, IslandRunLobby.tsx, raidLobbyService)
    // Was missing → default deny blocked all reads/writes; clients stayed on "Loading..." forever.
    match /islandRunLobbies/{lobbyId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.hostId;
      // Join / ready / start / heartbeat update the lobby doc; host and players coordinate here.
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    match /islandRunLobbies/{lobbyId}/members/{memberId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && request.auth.uid == memberId;
      allow delete: if request.auth != null && request.auth.uid == memberId;
    }

    // Shared battle session state (Squad Up / BattleEngine) — participantUids set in app for rule checks
    match /battleSessions/{battleId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.hostId &&
        request.resource.data.participantUids is list &&
        request.auth.uid in request.resource.data.participantUids;
      allow update, delete: if request.auth != null && (
        request.auth.uid == resource.data.hostId ||
        (resource.data.participantUids is list && request.auth.uid in resource.data.participantUids)
      );
    }
    
    // Default rule - deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}