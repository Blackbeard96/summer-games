rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allow authenticated users to read and write their own files
    match /manifestation_submissions/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Allow authenticated users to upload badge images
    match /badges/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    // Allow authenticated users to upload profile pictures
    match /profile_pictures/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Allow authenticated users to upload avatars (legacy path)
    match /avatars/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Allow authenticated users to upload and read training grounds images
    match /trainingGrounds/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    // Artifact images (admin/equippable artifacts) - authenticated users can upload; anyone can read for display
    match /artifacts/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Mission sequence media (slides, videos, posters) - admins upload; any auth user can read for gameplay
    match /missions/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Battle pass season intro media (hero video + intro sequence) — same access pattern as missions
    match /battlePass/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    // CPU opponent images (admin uploads in CPU Opponent Moves Admin) - anyone can read for battle display
    match /cpu_opponents/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Default rule - deny all other access
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
} 